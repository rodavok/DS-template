# Copy this file to .env and fill in your values.
# .env is gitignored so secrets stay local.

# ntfy.sh topic for mobile push notifications on sweep completion.
# Subscribe to this topic at https://ntfy.sh or in the ntfy app.
# Choose a unique name — anyone who knows it can publish/subscribe.
NTFY_TOPIC=your-unique-topic-name-here

# Optional: override the MLflow experiment name (default: kaggle-competition)
# MLFLOW_EXPERIMENT=my-competition-name
